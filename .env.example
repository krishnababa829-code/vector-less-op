# Zero-Null Vectorless RAG Configuration

# LLM Configuration (llama.cpp server)
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=sk-local
LLM_MODEL=qwen2.5-3b-instruct

# Token limits
MAX_TOKENS_PER_CHUNK=6000
MAX_SIGNPOST_TOKENS=30
MAX_CONTEXT_TOKENS=4096

# Crawler settings
CRAWL_DELAY_MS=500
MAX_CONCURRENT_REQUESTS=5
MAX_DEPTH=3
RENDER_JS=true

# Data storage
DATA_DIR=./data

# API Server
API_HOST=0.0.0.0
API_PORT=8080

# Logging
LOG_LEVEL=INFO
